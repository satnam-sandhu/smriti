# OpenRouter (layout learning via Gemini or other multimodal models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional OpenRouter metadata
OPENROUTER_SITE_URL=https://smriti.local
OPENROUTER_APP_NAME=Smriti

# Optional: override Smriti project root and workspace for MCP / Tauri
# SMRITI_ROOT=/absolute/path/to/smriti
# SMRITI_WORKSPACE=/absolute/path/to/smriti/data

# OpenRouter (layout learning via Gemini or other multimodal models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional OpenRouter metadata
OPENROUTER_SITE_URL=https://smriti.local
OPENROUTER_APP_NAME=Smriti

# Local stack — Smriti desktop + NitroChat (override cloud URLs)
VITE_MCP_SERVER_URL=http://localhost:3000
VITE_NITROCHAT_BASE_URL=http://localhost:3003

# Optional: override Smriti project root and workspace for MCP / Tauri
# SMRITI_ROOT=/absolute/path/to/smriti
SMRITI_WORKSPACE=data

# --- Connectors (optional) ------------------------------------------------
# Credentials can be passed inline via the connector --config JSON instead of
# these env vars. Env vars are the SDK-standard fallback when config omits them.
#
# Amazon S3 (requires: pip install boto3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
#
# Google Cloud Storage (requires: pip install google-cloud-storage)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Azure Blob Storage (requires: pip install azure-storage-blob)
# AZURE_STORAGE_CONNECTION_STRING=

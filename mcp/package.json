{
  "name": "smriti-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Smriti NitroStack MCP server — document ingestion tools",
  "scripts": {
    "dev": "nitrostack-cli dev",
    "dev:http": "nitrostack-cli start",
    "build": "nitrostack-cli build",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "postinstall": "node scripts/setup-cloud-parser.mjs",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "@nitrostack/core": "^1",
    "zod": "^3.22.4",
    "@modelcontextprotocol/ext-apps": ">=0.1.0"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3"
  }
}

# NitroStack Configuration
NITRO_LOG_LEVEL=info
NITROSTACK_APP_MODE=openai
MCP_TRANSPORT_TYPE=dual
NODE_ENV=production
PORT=3000

# Smriti workspace — processed Bronze/Silver/Gold live under smriti/data/
# Paths are resolved relative to the mcp/ package (see smriti-paths.ts).
SMRITI_ROOT=..
SMRITI_WORKSPACE=data
# SMRITI_PYTHON=/absolute/path/to/smriti/parser/.venv/bin/python3

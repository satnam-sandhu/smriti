# NitroChat Environment Variables
# Copy this file to .env.local and fill in your values

# MCP Server Configuration (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3002
NEXT_PUBLIC_MCP_API_KEY=your_mcp_api_key_here

# AI Provider API Keys (At least one required)
# If a key is not provided, that provider will be disabled automatically
NEXT_PUBLIC_OPENAI_API_KEY=sk-...
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSyApKclRBst3LiiVMAXJ1EXVI_65cABcg2U

# Chat context limit (optional, default 50000)
# When the conversation exceeds this many tokens (estimated), user is prompted to start a new chat
# CHAT_CONTEXT_MAX_TOKENS=50000
# NEXT_PUBLIC_CHAT_CONTEXT_MAX_TOKENS=50000

# Focus mode (optional, default false)
# When true, the assistant only answers within MCP/tools context and politely declines off-topic or vague questions
# FOCUS_MODE=true
# NEXT_PUBLIC_FOCUS_MODE=true

# NitroChat Gateway (optional): when set, chat is routed through the gateway (OpenRouter)
# NITROCHAT_GATEWAY_ENDPOINT=https://...
# NITROCHAT_GATEWAY_API_KEY=...
# When false (default), chat uses NITROCHAT_MODEL only; the UI model picker is hidden.
# NITROCHAT_MODEL_SELECTION=false
# OpenRouter model id used for all requests when NITROCHAT_MODEL_SELECTION is not true
# Prefer a currently routed id (google/gemini-2.0-flash-exp:free may 404 if OpenRouter has no providers).
# NITROCHAT_MODEL=google/gemini-2.5-flash
# NITROCHAT_MODEL=google/gemini-2.0-flash-001
# NITROCHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Notes:
# - API keys are loaded server-side only
# - Users will NOT be asked to provide their own keys
# - Only configured providers will be available in the app
# - If both keys are provided, users can switch between providers

# ============================================================
# Zitadel login (optional, in addition to existing OAuth)
# ============================================================
# When ZITADEL_ENABLED is exactly "true" and the core vars below are set,
# nitrochat exposes a "Sign in with Zitadel" button alongside the
# existing OAuth login (neither replaces the other). Every Zitadel API
# route (/api/auth/zitadel/*) returns 503 when this flag is off.
#
# These values are typically injected by NitroCloud from the IPS module
# (backend/src/zitadel) plus OpenBao for the client secret.
#
# ZITADEL_ENABLED=false
# ZITADEL_ISSUER=https://zitadel.example.com
# ZITADEL_CLIENT_ID=220000000000000003@nitrocloud
# ZITADEL_CLIENT_SECRET=change-me
# Optional explicit redirect URI. If unset, derived from APP_URL / NEXT_PUBLIC_APP_URL.
# ZITADEL_REDIRECT_URI=
# Optional audience override. Defaults to ZITADEL_CLIENT_ID.
# ZITADEL_AUDIENCE=
# Optional UI label shown on the Zitadel button.
# ZITADEL_LOGIN_LABEL=Sign in with Zitadel
# Optional Zitadel organization id. When set, login requests pin sign-in /
# self-registration to this org via the `urn:zitadel:iam:org:id:{id}` scope.
# ZITADEL_ORGANIZATION_ID=

# ---- Flow B: per-instance project-role enforcement ---------------------
# When ZITADEL_PROJECT_ID is set (NitroCloud writes it on every deploy
# from `instance.zitadelConfig.zitadelProjectId`), the login route adds
# project-aud + roles scopes so the access token carries the user's
# project-role grants, and `/api/auth/zitadel/{token,refresh}` reject
# tokens that lack one of `ZITADEL_REQUIRED_ROLE_KEYS` (default `member`).
# Leaving ZITADEL_PROJECT_ID unset reverts to Flow A (any org user with
# a valid token can use this NitroChat).
# ZITADEL_PROJECT_ID=
# Comma-separated role keys; ANY match grants access. Default: member.
# ZITADEL_REQUIRED_ROLE_KEYS=member
# Set to "false" to temporarily disable enforcement even when
# ZITADEL_PROJECT_ID is configured (e.g. during a backfill rollout).
# ZITADEL_ENFORCE_PROJECT_ROLES=true


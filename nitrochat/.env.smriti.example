# NitroChat — Smriti local dev
# Copy to .env.local and fill in gateway credentials.

NEXT_PUBLIC_APP_URL=http://localhost:3003

# Local Smriti MCP (npm run dev:mcp). Override with deployed URL for cloud testing.
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3000
MCP_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_MCP_API_KEY=

# NitroChat Gateway (required for chat completions)
NITROCHAT_GATEWAY_ENDPOINT=
NITROCHAT_GATEWAY_API_KEY=
NITROCHAT_MODEL_SELECTION=false
NITROCHAT_MODEL=google/gemini-2.5-flash

# Optional: point runtime config at Smriti-branded JSON (default in repo)
# RUNTIME_CONFIG_PATH=config/runtime-config.json

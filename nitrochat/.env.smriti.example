# NitroChat — Smriti local dev
# Copy to nitrochat/.env.local and set NITROCHAT_GATEWAY_API_KEY.

NEXT_PUBLIC_APP_URL=http://localhost:3003

# Local Smriti MCP (npm run dev:mcp)
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3000
MCP_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_MCP_API_KEY=

# NitroStack gateway for LLM chat completions (not direct provider keys)
NITROCHAT_GATEWAY_ENDPOINT=https://gateway.dev.nitrostack.ai
NITROCHAT_GATEWAY_API_KEY=
NITROCHAT_MODEL_SELECTION=false
NITROCHAT_MODEL=openai/gpt-4o-mini
FOCUS_MODE=true

# Disable Zitadel for simple local dev (optional)
ZITADEL_ENABLED=false
NEXT_PUBLIC_THREADS_ENABLED=false
